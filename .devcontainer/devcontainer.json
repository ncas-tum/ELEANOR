{
	"name": "Python 3",
	"image": "ferqui/devenv",
	"hostRequirements": {
		"gpu": "optional"
	},
	"runArgs": [
		"--gpus=all",
		"--privileged"
	],
	"customizations": {
		// Configure properties specific to VS Code.
		"vscode": {
			"extensions": [
				"ms-python.python",
				"ms-python.flake8",
				"ms-toolsai.jupyter",
				"ms-python.vscode-pylance",
				"ms-python.debugpy",
				"ms-python.isort",
				"ms-vscode.cpptools-extension-pack"
			]
		}
	},
	"postCreateCommand": "bash install.sh"
}
